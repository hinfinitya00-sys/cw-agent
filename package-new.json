{
  "name": "cw-agent-automation",
  "version": "2.0.0",
  "description": "CrowdWorks Complete Automation System - AI-powered job search, evaluation, and application",
  "main": "server-auto.js",
  "scripts": {
    "start": "node server-auto.js",
    "dev": "nodemon server-auto.js",
    "test": "npm run lint && npm run test:unit",
    "lint": "eslint *.js",
    "test:unit": "jest",
    "install-deps": "npm install",
    "setup": "npm install && echo '✅ CW-Agent setup complete. Run: npm start'",
    "docker:build": "docker build -t cw-agent .",
    "docker:run": "docker run -p 3456:3456 cw-agent"
  },
  "keywords": [
    "crowdworks",
    "automation",
    "ai",
    "claude",
    "freelance",
    "job-search",
    "web-scraping",
    "puppeteer"
  ],
  "author": "CW-Agent Development Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "puppeteer": "^21.11.0",
    "cheerio": "^1.0.0-rc.12",
    "node-cron": "^3.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "validator": "^13.11.0",
    "axios": "^1.6.2",
    "moment": "^2.29.4",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "multer": "^1.4.5-lts.1",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@eslint/js": "^8.56.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hinfinitya00-sys/cw-agent.git"
  },
  "bugs": {
    "url": "https://github.com/hinfinitya00-sys/cw-agent/issues"
  },
  "homepage": "https://github.com/hinfinitya00-sys/cw-agent#readme",
  "config": {
    "port": 3456,
    "environment": "development"
  },
  "babel": {
    "presets": ["@babel/preset-env"]
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "*.js",
      "!node_modules/**",
      "!coverage/**"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  }
}
